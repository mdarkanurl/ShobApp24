generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id
  name                  String
  email                 String
  emailVerified         Boolean   @default(false)
  image                 String?
  stripeCustomerId      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  sessions              Session[]
  accounts              Account[]
  workflows             Workflow[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model GithubConnection {
  id                String    @id    @default(cuid())
  userId            String?
  installationId    Int       @unique
  username          String
  url               String
  html_url          String
  avatar_url        String
  type              TypesOfGitHubAccount
  repos_url         String
  GitHubAccountId   Int

  Repos             GitHubRepo[]

  createdAt         DateTime         @default(now())

  @@index([userId])
  @@map("github_connection")
}

model GitHubRepo {
  id                             String   @id    @default(cuid())
  GithubConnectionsId            String
  GithubConnections              GithubConnection     @relation(fields: [GithubConnectionsId], references: [id], onDelete: Cascade)
  repoId                         Int      @unique
  name                           String
  full_name                      String
  private                        Boolean

  repos                         Workflow[]

  @@unique([GithubConnectionsId, repoId])
  @@map("github_repo")
}

model Workflow {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  platform      Platform
  enabled       Boolean     @default(true)

  repoId        String
  repo          GitHubRepo     @relation(fields: [repoId], references: [id], onDelete: Cascade)

  eventType     EventType
  action        String?
  config        Json?

  actions       Action[]
  runs          WorkflowRun[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@map("workflow")
}

model Action {
  id            String     @id @default(cuid())
  workflowId    String
  workflow      Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  platform      Platform
  type          ActionTypes
  config        Json?
  step          Int

  createdAt     DateTime   @default(now())
  runs          ActionRun[]

  @@index([workflowId])
  @@index([platform, type])
  @@map("action")
}

model WorkflowRun {
  id            String       @id @default(cuid())
  workflowId    String
  workflow      Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  platform      Platform
  eventType     EventType
  payload       Json?
  output        Json?

  status        RunStatus

  actionRuns    ActionRun[]

  startedAt     DateTime     @default(now())
  finishedAt    DateTime?

  @@index([workflowId])
  @@index([platform, eventType])
  @@map("workflow_run")
}

model ActionRun {
  id             String        @id @default(cuid())

  workflowRunId  String
  workflowRun    WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  actionId       String
  action         Action        @relation(fields: [actionId], references: [id], onDelete: Cascade)

  status         RunStatus
  input          Json?
  output         Json?
  error          String?

  startedAt      DateTime      @default(now())
  finishedAt     DateTime?

  @@map("action_run")
}

// Stripe
model Subscriptions {
  id                    String @id @default(cuid())

  userId                String?
  stripeCustomerId      String?
  stripeSubscriptionId  String @unique
  stripePriceId         String?

  status                SubscriptionsStatus

  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?

  payments              Payments[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("subscriptions")
  @@index([stripeSubscriptionId])
}

model Payments {
  id                    String            @id @default(cuid())

  stripeInvoiceId       String            @unique
  invoice               Subscriptions     @relation(fields: [stripeInvoiceId], references: [id], onDelete: Cascade)

  stripeSubscriptionId  String
  amount Int
  currency String
  status PaymentsStatus
  paidAt DateTime

  createdAt DateTime @default(now())
}

enum PaymentsStatus {
  processing
  succeeded
  amount_capturable_updated
  payment_failed
}

enum SubscriptionsStatus {
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused
}

enum TypesOfGitHubAccount {
  User
  Organization
  Enterprise
}

enum EventType {
  installation
  star
  watch
  label
  issues
  issue_comment
  push
  pull_request
  repository
  commit_comment
  fork
  pull_request_review
  create
  delete
  workflow_job
  workflow_run
}

enum RunStatus {
  Running
  Succeeded
  Failed
}

enum Platform {
  GitHub
}

enum WorkflowStatus {
  Active
  Disabled
}

enum ActionTypes {
  // Universal types. The config of these types don't change
  collect_viewer_data
  webhook
  send_telegram
  analytics_data_by_AI
  send_email_to_who_send_the_trigger
  send_email
  send_email_to_me

  // push event
  send_email_to_who_push_the_commit
  send_email_to_me_for_push_event
  send_email_for_push_event

  // issues event
  analytics_the_issue_and_give_rating
  send_email_for_issues_event
  send_email_to_me_for_issues_event

  // repository event
  send_email_for_repository_event

  // star event
  send_email_for_star_event
}
